{
  "name": "waqup",
  "version": "1.0.0",
  "private": true,
  "description": "waQup multi-platform application - Mobile (React Native + Expo for Android/iOS) and Web (Next.js for desktop browsers)",
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "rimraf": "^5.0.0",
    "glob": "^10.4.5"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset",
    "supabase:push": "supabase db push",
    "supabase:migrate": "bash supabase/scripts/run_migrations.sh",
    "supabase:diff": "supabase db diff",
    "verify:db": "bash supabase/scripts/run_verify.sh",
    "dev:local": "supabase start && npm run dev:web",
    "dev:mobile": "npm run start --workspace=packages/mobile",
    "dev:web": "npm run dev --workspace=packages/web",
    "warmup:dev": "npm run warmup:dev --workspace=packages/web",
    "dev:web:clean": "rm -rf packages/web/.next 2>/dev/null; (lsof -ti:3000 2>/dev/null|xargs kill -9) || true; (lsof -ti:3002 2>/dev/null|xargs kill -9) || true; npm run dev:web",
    "dev:all": "npm run dev:mobile & npm run dev:web",
    "dev:all:clean": "rm -rf packages/web/.next 2>/dev/null; (lsof -ti:3000 2>/dev/null|xargs kill -9) || true; (lsof -ti:3002 2>/dev/null|xargs kill -9) || true; (lsof -ti:8081 2>/dev/null|xargs kill -9) || true; npm run dev:all",
    "dev:all:win": "npm run dev:mobile & npm run dev:web",
    "build:shared": "npm run build --workspace=packages/shared",
    "build:mobile": "npm run build --workspace=packages/mobile",
    "build:web": "npm run build --workspace=packages/web",
    "build:web:clean": "rm -rf packages/web/.next && npm run build:web",
    "start:web": "npm run start --workspace=packages/web",
    "prod:web": "npm run build:web && npm run start:web",
    "build:all": "npm run build:shared && npm run build:mobile && npm run build:web",
    "test": "npm run test --workspaces",
    "test:all": "npm run test --workspace=@waqup/shared && npm run test --workspace=mobile && npm run test:e2e:critical",
    "test:e2e": "npm run test:e2e --workspace=packages/web",
    "test:e2e:critical": "npm run test:e2e:critical --workspace=packages/web",
    "test:e2e:web": "npm run test:e2e --workspace=packages/web",
    "test:e2e:desktop": "npm run test:e2e:desktop --workspace=packages/web",
    "test:e2e:mobile": "npm run test:e2e:mobile --workspace=packages/web",
    "test:e2e:headed": "npm run test:e2e:headed --workspace=packages/web",
    "test:e2e:ui": "npm run test:e2e:ui --workspace=packages/web",
    "test:e2e:report": "npm run test:e2e:report --workspace=packages/web",
    "test:e2e:install": "npm run test:e2e:install --workspace=packages/web",
    "lint": "npm run lint --workspaces",
    "type-check": "npm run type-check --workspaces"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "supabase": "^2.77.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/InnerFlect-Tech/waqup-new.git"
  },
  "keywords": [
    "waqup",
    "mobile",
    "desktop",
    "web",
    "react-native",
    "expo",
    "nextjs"
  ],
  "author": "InnerFlect Tech",
  "license": "UNLICENSED"
}
