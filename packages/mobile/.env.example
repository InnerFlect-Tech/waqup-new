# ==============================================================================
# Mobile (Expo) — Environment Variables
# ==============================================================================
# Copy to .env.local and fill in real values.
# Values must match what you use in root .env.local for the web app.
#
# Android emulator: replace 127.0.0.1 with 10.0.2.2
# Physical device: use your machine's local IP (e.g. 192.168.1.x)
# ==============================================================================

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
EXPO_PUBLIC_API_URL=http://localhost:3000

# RevenueCat (IAP)
# Get from RevenueCat Dashboard → Project → API Keys
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# RevenueCat Webhook (backend only — used to verify purchase callbacks and grant Qs)
# Get from RevenueCat Dashboard → Project → Webhooks
REVENUECAT_WEBHOOK_SECRET=your_webhook_authorization_header
