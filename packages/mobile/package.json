{
  "name": "mobile",
  "version": "0.9.0",
  "main": "index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --ci --watchAll=false --passWithNoTests",
    "start": "npx expo start",
    "start:tunnel": "npx expo start --tunnel --port 8082",
    "start:clear": "npx expo start --clear",
    "android": "npx expo start --android",
    "ios": "npx expo start --ios",
    "web": "npx expo start --web",
    "type-check": "tsc --noEmit",
    "lint": "echo 'Lint not configured for mobile'"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.1.0",
    "@react-navigation/drawer": "^7.9.4",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.1.0",
    "@sentry/react-native": "~7.2.0",
    "@tanstack/query-async-storage-persister": "^5.90.24",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-persist-client": "^5.90.24",
    "@waqup/shared": "*",
    "axios": "^1.13.4",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.4",
    "expo": "~54.0.33",
    "expo-av": "^16.0.8",
    "expo-blur": "^15.0.8",
    "expo-constants": "^18.0.13",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "i18next": "^25.8.17",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^16.5.6",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-purchases": "^9.11.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.8.0",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.1.0",
    "@types/react-native": "^0.72.8",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "typescript": "~5.9.3"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|react-native-svg)"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ]
  },
  "private": true
}
