# Local Supabase (from `supabase start` output at repo root)
# Copy to .env or .env.local. The anon key is printed when you run `supabase start`.
#
# For Android emulator: use 10.0.2.2 instead of 127.0.0.1
# For iOS Simulator: localhost or 127.0.0.1 works
# For physical device: use your machine's local IP (e.g. 192.168.1.x)
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<local-anon-key-from-supabase-start>
