{
  "name": "web",
  "version": "0.9.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "warmup:dev": "node scripts/warmup-dev.mjs",
    "build": "next build --webpack",
    "test": "echo 'Web: use test:e2e or test:e2e:critical'",
    "start": "next start",
    "copy-standalone-assets": "mkdir -p .next/standalone/packages/web/.next && cp -r .next/static .next/standalone/packages/web/.next/ && cp -r public .next/standalone/packages/web/ 2>/dev/null || true",
    "start:standalone": "npm run copy-standalone-assets && cd .next/standalone && node packages/web/server.js",
    "lint": "eslint app src --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:critical": "playwright test specs/critical-flows.spec.ts --project=desktop-chromium --project=desktop-chromium-authenticated --project=mobile-chrome --project=mobile-safari",
    "test:e2e:desktop": "playwright test --project=desktop-chromium --project=desktop-chromium-authenticated",
    "test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:install": "playwright install",
    "test:e2e:public": "playwright test specs/public/ specs/i18n/ --project=desktop-chromium --project=i18n",
    "test:e2e:public:batch1": "playwright test specs/public/landing.spec.ts --project=desktop-chromium",
    "test:e2e:public:batch2": "playwright test specs/public/marketing.spec.ts --project=desktop-chromium",
    "test:e2e:public:batch3": "playwright test specs/public/for-professionals.spec.ts --project=desktop-chromium",
    "test:e2e:public:batch4": "playwright test specs/public/auth-pages.spec.ts --project=desktop-chromium",
    "test:e2e:public:batch5": "playwright test specs/i18n/ --project=i18n",
    "stripe:webhook:listen": "stripe listen --forward-to localhost:3000/api/stripe/webhook",
    "stripe:webhook:create": "node --env-file=.env.local scripts/create-stripe-webhook.mjs",
    "icons:crop": "node scripts/process-icon-crop.mjs",
    "verify:i18n": "node scripts/verify-i18n.mjs"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@hookform/resolvers": "^5.2.2",
    "@react-three/drei": "^10.6.0",
    "@react-three/fiber": "^9.0.0",
    "@stripe/stripe-js": "^4.10.0",
    "@supabase/ssr": "^0.5.2",
    "@tanstack/react-query": "^5.90.21",
    "@vercel/analytics": "^1.6.1",
    "@vercel/og": "^0.11.1",
    "@waqup/shared": "*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.563.0",
    "mermaid": "^11.12.3",
    "next": "^16.1.6",
    "next-intl": "^4.8.3",
    "ogl": "^1.0.8",
    "openai": "^4.77.0",
    "p5": "^1.11.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^10.1.0",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.4.1",
    "uuid": "^13.0.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24.0.0",
    "@types/p5": "^1.7.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "dotenv": "^17.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5.9.3"
  }
}
