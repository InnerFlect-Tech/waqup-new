# App URL (required for OAuth redirect in production; set to your deployment URL)
# e.g. https://waqup-new.vercel.app or https://waqup.com
NEXT_PUBLIC_APP_URL=https://your-app-url.com

# Supabase (required for auth and data)
# From https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

# Test login (optional, temporary): one-click login without database for testing.
# Set to true to show "Test login (no DB)" on login page and "Test logout" in header when test user.
# Disable (omit or false) for production.
# NEXT_PUBLIC_ENABLE_TEST_LOGIN=true

# Override login (optional): sign in without Supabase and access app pages.
# Set both to enable. Do not use in production or use a strong password.
# OVERRIDE_LOGIN_EMAIL=admin@example.com
# OVERRIDE_LOGIN_PASSWORD=your-secure-password

# Stripe (for pricing/checkout)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=your_stripe_starter_price_id
NEXT_PUBLIC_STRIPE_GROWTH_PRICE_ID=your_stripe_growth_price_id
NEXT_PUBLIC_STRIPE_DEVOTION_PRICE_ID=your_stripe_devotion_price_id

# Server-side only (for API routes if needed later – do not expose to client)
# SUPABASE_SECRET_KEY=your_supabase_service_role_key
# STRIPE_SECRET_KEY=your_stripe_secret_key
# OPENAI_API_KEY=your_openai_api_key
# ELEVENLABS_API_KEY=your_elevenlabs_api_key

# --- Local development (see packages/web/.env.local.example) ---
# For local Supabase: copy .env.local.example to .env.local and use values from `supabase start` output.
