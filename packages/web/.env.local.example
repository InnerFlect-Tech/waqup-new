# =============================================================================
# packages/web/.env.local — Local overrides for Next.js web app
# =============================================================================
# Copy this file to .env.local and fill in values for your chosen mode.
# .env.local is gitignored and takes priority over the root .env.
#
# TWO MODES:
#   Mode A — Remote Supabase Dev (quick, uses cloud DB from localhost)
#   Mode B — Local Supabase Dev  (fully isolated, safe for schema work)
#
# See docs/04-reference/12-local-development.md for full setup guide.
# =============================================================================

# --- MODE A: Remote Supabase from localhost -----------------------------------
# Use your production Supabase project but run the Next.js app locally.
# Get these from: https://supabase.com/dashboard → Project Settings → API
#
# NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-key>
# NEXT_PUBLIC_APP_URL=http://localhost:3000
#
# Required Supabase dashboard step (one-time):
#   Auth → URL Configuration → add http://localhost:3000/** to Redirect URLs
# Required Google Cloud Console step (one-time):
#   OAuth client → add http://localhost:3000 to JS origins
#                  add http://localhost:3000/auth/callback to redirect URIs

# --- MODE B: Local Supabase (fully isolated) ----------------------------------
# Run `npm run supabase:start` first, then copy values from its output.
#
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<anon-key-from-supabase-start-output>
# NEXT_PUBLIC_APP_URL=http://localhost:3000
#
# Requires Docker running. See docs/04-reference/12-local-development.md.

# --- Active values (uncomment one block above and paste values here) ----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Required for OAuth redirects to work from localhost:
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Server-side secrets (API routes only, never exposed to browser) ----------
# OPENAI_API_KEY=sk-proj-...
# ELEVENLABS_API_KEY=sk_...
# STRIPE_SECRET_KEY=sk_test_...
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>  # for admin operations only

# --- Stripe (for pricing/checkout) -------------------------------------------
# Use test-mode keys (pk_test_..., sk_test_...) for local dev:
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_...
# NEXT_PUBLIC_STRIPE_GROWTH_PRICE_ID=price_...
# NEXT_PUBLIC_STRIPE_DEVOTION_PRICE_ID=price_...
