# Local Supabase (from `supabase start` output - copy URL and anon key)
# Run: npm run supabase:start (or supabase start) and copy values from the output
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<local-anon-key-from-supabase-start>

# OAuth redirect for local development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: dev shortcuts for quick testing
# NEXT_PUBLIC_ENABLE_TEST_LOGIN=true
# OVERRIDE_LOGIN_EMAIL=dev@local.test
# OVERRIDE_LOGIN_PASSWORD=devpassword

# Stripe test mode (use pk_test_... and sk_test_... for local)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_...
# NEXT_PUBLIC_STRIPE_GROWTH_PRICE_ID=price_...
# NEXT_PUBLIC_STRIPE_DEVOTION_PRICE_ID=price_...
# STRIPE_SECRET_KEY=sk_test_...
