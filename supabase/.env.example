# =============================================================================
# supabase/.env — Secrets for local Supabase stack (Mode B: Local Supabase)
# =============================================================================
# Copy this file to supabase/.env and fill in your OAuth credentials.
# supabase/.env is gitignored — never commit real credentials.
#
# These values are read by supabase/config.toml via env() references.
# After creating this file, restart the local stack:
#   supabase stop && supabase start
#
# See docs/04-reference/12-local-development.md → "Mode B: Local Supabase"
# =============================================================================

# --- Google OAuth -------------------------------------------------------------
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Create an "OAuth 2.0 Client ID" of type "Web application"
# Authorized redirect URIs must include: http://127.0.0.1:54321/auth/v1/callback
#
SUPABASE_AUTH_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
SUPABASE_AUTH_GOOGLE_SECRET=your-client-secret

# --- Other OAuth providers (add as needed) ------------------------------------
# SUPABASE_AUTH_GITHUB_CLIENT_ID=
# SUPABASE_AUTH_GITHUB_SECRET=
# SUPABASE_AUTH_APPLE_CLIENT_ID=
# SUPABASE_AUTH_APPLE_SECRET=
