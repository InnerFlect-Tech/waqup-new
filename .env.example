# ==============================================================================
# waQup — Environment Variables (Master Reference)
# ==============================================================================
# LOCAL DEV:  cp .env.example .env.local  →  fill in real values
# DEPLOY:     Set in Vercel → Project Settings → Environment Variables
#
# NEVER commit .env.local or any file with real secrets.
# This file contains placeholder values only and is safe to commit.
#
# See docs/04-reference/12-local-development.md for full setup guide.
# ==============================================================================

# ------------------------------------------------------------------------------
# Supabase (required for auth and all data)
# Get from: https://supabase.com/dashboard → Project Settings → API
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
# Service role key — server-side only (webhooks, admin routes). NEVER expose to browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Optional: direct Postgres connection for verify:db (npm run verify:db)
# Get from: Dashboard → Project Settings → Database → Connection string (URI)
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# ------------------------------------------------------------------------------
# App URL
# Local dev:   http://localhost:3000
# Production:  set to your real domain in Vercel (e.g. https://waqup.com)
# Required for Google OAuth redirects to work correctly.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# AI — server-side only, never exposed to the browser
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-...
ELEVENLABS_API_KEY=sk_...
# Optional: override default oracle voice (when user has no admin-configured voice). Default: Rachel.
# DEFAULT_ORACLE_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ------------------------------------------------------------------------------
# Stripe
# Local dev: use test-mode keys (pk_test_..., sk_test_...)
# Production: use live keys in Vercel
# ------------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret — get from Stripe Dashboard → Webhooks → Signing secret
# Local dev: use `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=whsec_...

# Subscription plan price IDs (create in Stripe Dashboard → Products)
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_GROWTH_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_DEVOTION_PRICE_ID=price_...

# One-time credit pack price IDs (create as one-time prices in Stripe Dashboard)
NEXT_PUBLIC_STRIPE_SPARK_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_CREATOR_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_FLOW_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_DEVOTION_PACK_PRICE_ID=price_...

# ------------------------------------------------------------------------------
# RevenueCat — iOS In-App Purchase webhooks
# Set Authorization header in RevenueCat Dashboard → Integrations → Webhooks → "Bearer <this_value>"
# ------------------------------------------------------------------------------
REVENUECAT_WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# Meta (Facebook/Instagram) Webhooks — for real-time notifications
# Get App Secret: developers.facebook.com → Your App → Settings → Basic
# Verify Token: choose any secret string; must match value in Meta Dashboard
# ------------------------------------------------------------------------------
META_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=

# ------------------------------------------------------------------------------
# Instagram Graph API — for real follower count on the launch/marketing page
# How to get:
#   1. Go to developers.facebook.com → your app → Instagram Graph API
#   2. Generate a long-lived User Token with: instagram_basic, pages_show_list
#   3. Find your Instagram User ID by calling:
#      GET https://graph.instagram.com/me?fields=id&access_token={TOKEN}
# Note: Long-lived tokens expire after 60 days — refresh via
#      GET https://graph.instagram.com/refresh_access_token?grant_type=ig_refresh_token&access_token={TOKEN}
# ------------------------------------------------------------------------------
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# ------------------------------------------------------------------------------
# ClickUp — feedback sync (optional)
# If set, feedback from /sanctuary/help is also sent to ClickUp as tasks.
# Get API token: ClickUp Settings → Apps → API Token
# List ID: from URL app.clickup.com/.../list/123456789
# ------------------------------------------------------------------------------
CLICKUP_API_KEY=
CLICKUP_FEEDBACK_LIST_ID=

# ------------------------------------------------------------------------------
# Dev shortcuts — disable or omit in production
# ------------------------------------------------------------------------------
# Show "Test login (no DB)" button on login page:
NEXT_PUBLIC_ENABLE_TEST_LOGIN=false

# Override login (sign in without Supabase — local dev + E2E only):
# Server validates; client needs matching NEXT_PUBLIC_* for Test login button.
OVERRIDE_LOGIN_EMAIL=
OVERRIDE_LOGIN_PASSWORD=
NEXT_PUBLIC_OVERRIDE_LOGIN_EMAIL=
NEXT_PUBLIC_OVERRIDE_LOGIN_PASSWORD=

# ------------------------------------------------------------------------------
# Mobile (Expo) — set in packages/mobile/.env.local, NOT here
# Next.js ignores EXPO_PUBLIC_* vars; Expo reads from its own package directory.
# ------------------------------------------------------------------------------
# EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
# EXPO_PUBLIC_API_URL=http://localhost:3000
